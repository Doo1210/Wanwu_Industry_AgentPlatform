                const modelParams = [
                    { key: 'temperature', label: '温度', tip: '增加温度将使模型的回答更具创造性', min: 0, max: 2, step: 0.1 },
                    { key: 'topP', label: 'TopP', tip: '生成过程中核采样方法概率阈值。取值越大，生成的随机性越高', min: 0, max: 1, step: 0.05 },

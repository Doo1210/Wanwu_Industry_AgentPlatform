                const toggleSection = (key) => {
                    expandedSections.value[key] = !expandedSections.value[key];
                };

                const scrollToSection = (sectionId) => {
                    activeSection.value = sectionId;
                    const key = sectionKeyMap[sectionId];
                    if (key) expandedSections.value[key] = true;
                    nextTick(() => {
                        const el = document.getElementById(sectionId);
                        if (el && contentContainer.value) {
                            const container = contentContainer.value;
                            const containerRect = container.getBoundingClientRect();
                            const elRect = el.getBoundingClientRect();
                            container.scrollTo({ top: container.scrollTop + elRect.top - containerRect.top - 8, behavior: 'smooth' });
                        }
                    });
                };

                // IntersectionObserver 联动导航
                let observer = null;
                const setupObserver = () => {
                    if (observer) observer.disconnect();
                    if (!contentContainer.value) return;
                    observer = new IntersectionObserver((entries) => {
                        const visible = entries.filter(e => e.isIntersecting);
                        if (visible.length > 0) {
                            visible.sort((a, b) => a.intersectionRatio - b.intersectionRatio);
                            activeSection.value = visible[visible.length - 1].target.id;
                        }
                    }, { root: contentContainer.value, rootMargin: '-10% 0px -70% 0px', threshold: 0 });
                    ['section-profile','section-resources','section-logic','section-safety'].forEach(id => {
                        const el = document.getElementById(id);
                        if (el) observer.observe(el);
                    });
                };

                nextTick(() => setupObserver());

                // ===== 表单数据 =====
                const form = ref({
                    name: '变压器异常诊断专家',
                    model: 'qwen',
                    responsibility: '你是一个严谨的电气工程师，主要负责一号车间的电气设备异常诊断，确保设备安全运行。',
                    knowledge: {
                        rag: ['《西门子变压器运维手册V2.pdf》', '《2023年历史故障代码库》'],
                        faq: ['变压器常见故障处理50问'],
                        db: ['设备运行台账数据库']

                    security: [
                        { tool: '[Modbus] 设备急停/复位', config: { mode: 'approval', notifyChannel: 'wecom', approver: 'li' } },
                        { tool: '[WeCom] 企业微信消息通知', config: { mode: 'rule', valueBounds: [], frequencyLimit: { maxTimes: 1, timeWindow: 5, unit: '分钟' }, violationStrategy: 'block' } }
                    ],
                    logic: {
                        allowExploration: true,
                        behaviorGuidelines: '1. 始终优先保障人员安全；2. 执行控制操作前必须二次确认数据准确性；3. 重大决策需保留完整操作日志'
                    },
                    sops: [
                        {
                            id: 'sk_1',
                            businessDesc: '当变压器油温超过85℃时，先查过去一小时的负载，如果正常就通知班长，如果负载也异常偏高，就立刻执行设备急停，并派发工单记录。',
                            compiledPrompt: `[SCENARIO]: Event alarm_type == "High_Temperature" && > 85℃\n[LOGIC]:\n  1. CALL [读取实时遥测数据] to check load over past 1 hour.\n  2. IF load is NORMAL, CALL [企业微信消息通知] to shift lead.\n  3. IF load is HIGH, CALL [设备急停/复位] IMMEDIATELY and CALL [派发维修工单].`,
                            tools: ['[读取实时遥测数据]', '[设备急停/复位]', '[企业微信消息通知]', '[派发维修工单]']
                        }
                    ]
                });

                // ===== 模型配置 =====
                const showModelDialog = ref(false);
                const modelConfig = ref({
                    temperatureEnabled: true, temperature: 0.7,
                    topPEnabled: true, topP: 1,
                    frequencyPenaltyEnabled: true, frequencyPenalty: 0,
                    presencePenaltyEnabled: true, presencePenalty: 0,
                    maxTokensEnabled: true, maxTokens: 512,
                    showThinking: true

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>数字员工配置</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/element-plus/dist/index.css" />
    <script src="https://unpkg.com/element-plus"></script>
    <script src="https://unpkg.com/@element-plus/icons-vue"></script>

    <style>
        :root { --brand-color: #3b82f6; }
        body { font-family: "Inter", -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif; margin: 0; padding: 0; background-color: #f1f5f9; }
        [v-cloak] { display: none; }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .terminal-scroll::-webkit-scrollbar-thumb { background: #475569; border-radius: 10px; }

        /* ===== 配置模块卡片 ===== */
        .module-card {
            background-color: #ffffff;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 16px -4px rgba(15, 23, 42, 0.07), 0 2px 4px -2px rgba(15, 23, 42, 0.04);
            margin-bottom: 20px;
            overflow: hidden;
            position: relative;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .module-card:hover {
            box-shadow: 0 10px 32px -6px rgba(15, 23, 42, 0.10), 0 4px 8px -4px rgba(15, 23, 42, 0.05);
            border-color: #cbd5e1;
        }
        .module-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; bottom: 0;
            width: 4px;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .module-card.accent-blue::before { background: linear-gradient(180deg, #3b82f6, #60a5fa); opacity: 1; }
        .module-card.accent-emerald::before { background: linear-gradient(180deg, #10b981, #34d399); opacity: 1; }
        .module-card.accent-indigo::before { background: linear-gradient(180deg, #6366f1, #818cf8); opacity: 1; }
        .module-card.accent-rose::before { background: linear-gradient(180deg, #f43f5e, #fb7185); opacity: 1; }

        .module-header {
            padding: 18px 24px 18px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            user-select: none;
            background-color: #ffffff;
            transition: background-color 0.2s ease;
            position: relative;
            z-index: 10;
        }
        .module-header:hover { background-color: #f8fafc; }
        .module-header.is-expanded { border-bottom: 1px solid #e2e8f0; }

        .icon-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px; height: 26px;
            color: #94a3b8;
            font-size: 13px;
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            transform: rotate(-90deg);
        }
        .icon-toggle-expanded { transform: rotate(0deg); }

        .module-body {
            padding: 18px 22px 22px 22px;
            background-color: #fafbfc;
        }

        /* ===== 表单元素 ===== */
        .form-label-simple {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #475569;
            margin-bottom: 6px;
        }
        .sub-card-simple {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 14px;
            transition: all 0.2s ease;
        }
        .sub-card-simple:hover { border-color: #cbd5e1; }

        .sop-card-simple {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            transition: all 0.2s ease;
        }
        .sop-card-simple:hover { border-color: #a5b4fc; background-color: #f5f3ff; }

        /* ===== 工具卡片 ===== */
        .tool-card {
            background-color: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
            gap: 4px;
            user-select: none;
        }
        .tool-card:hover { box-shadow: 0 4px 12px -3px rgba(15, 23, 42, 0.08); transform: translateY(-1px); }

        /* ===== AI 按钮 ===== */
        .ai-magic-btn {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            border: none; color: white;
            transition: all 0.3s ease;
            box-shadow: 0 4px 10px rgba(99, 102, 241, 0.2);
        }
        .ai-magic-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 15px rgba(99, 102, 241, 0.3); color: white; }

        /* ===== Element Plus 覆盖 ===== */
        .el-input__wrapper, .el-select__wrapper { box-shadow: 0 0 0 1px #e2e8f0 inset !important; }
        .el-input__wrapper:hover, .el-select__wrapper:hover { box-shadow: 0 0 0 1px #94a3b8 inset !important; }
        .el-input__wrapper.is-focus, .el-select__wrapper.is-focus { box-shadow: 0 0 0 1px var(--brand-color) inset !important; }
        
        .el-dialog { border-radius: 18px !important; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.22) !important; }
        .el-dialog__header {
            border-bottom: 1px solid #e2e8f0;
            padding: 14px 20px;
            display: flex;
            align-items: center;
        }
        .el-dialog__title { font-weight: 700; color: #0f172a; font-size: 15px; }
        .el-dialog__headerbtn {
            position: static !important;
            margin-left: auto;
            width: 28px;
            height: 28px;
            top: unset !important;
            right: unset !important;
        }
        .el-dialog__headerbtn .el-dialog__close {
            font-size: 16px;
            color: #94a3b8;
        }
        .el-dialog__headerbtn:hover .el-dialog__close { color: #475569; }
        .el-dialog__footer { border-top: 1px solid #e2e8f0; padding: 12px 20px; }
        /* 弹窗底部按钮统一样式 */
        .el-dialog__footer .el-button--primary {
            background-color: #3b82f6 !important;
            border-color: #3b82f6 !important;
            box-shadow: 0 4px 10px -2px rgba(59,130,246,0.35) !important;
        }
        .el-dialog__footer .el-button--primary:hover {
            background-color: #2563eb !important;
            border-color: #2563eb !important;
        }
        .el-dialog__footer .el-button:not(.el-button--primary) {
            color: #475569 !important;
            border-color: #e2e8f0 !important;
        }
        .el-dialog__footer .el-button:not(.el-button--primary):hover {
            color: #1e293b !important;
            border-color: #cbd5e1 !important;
            background-color: #f8fafc !important;
        }

        .border-l-3 { border-left-width: 3px; }
        .border-l-blue-500 { border-left-color: #3b82f6; }

        .help-icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 16px; height: 16px; border-radius: 50%;
            border: 1px solid #cbd5e1; font-size: 10px; font-weight: bold;
            color: #94a3b8; cursor: help; line-height: 1; flex-shrink: 0;
        }

        /* ===== 调试面板消息样式 ===== */
        .debug-msg-system {
            background: #f1f5f9;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 12px;
            color: #64748b;
            text-align: center;
        }
        .debug-msg-user {
            display: flex;
            justify-content: flex-end;
        }
        .debug-msg-user .bubble {
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            color: white;
            border-radius: 16px 16px 4px 16px;
            padding: 10px 14px;
            font-size: 13px;
            max-width: 80%;
            line-height: 1.5;
        }
        .debug-msg-tool {
            background: #faf5ff;
            border: 1px solid #e9d5ff;
            border-left: 3px solid #a855f7;
            border-radius: 8px;
            padding: 10px 14px;
            font-family: 'Fira Code', 'Consolas', monospace;
            font-size: 12px;
            color: #7c3aed;
            line-height: 1.6;
        }
        .debug-msg-assistant {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 4px 16px 16px 16px;
            padding: 12px 14px;
            font-size: 13px;
            color: #1e293b;
            line-height: 1.6;
            box-shadow: 0 2px 8px -2px rgba(15,23,42,0.06);
        }
        .debug-msg-thinking {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #94a3b8;
            font-size: 12px;
            padding: 4px 0;
        }
        .thinking-dot {
            width: 6px; height: 6px;
            background: #94a3b8;
            border-radius: 50%;
            animation: thinking-bounce 1.2s infinite;
        }
        .thinking-dot:nth-child(2) { animation-delay: 0.2s; }
        .thinking-dot:nth-child(3) { animation-delay: 0.4s; }
        @keyframes thinking-bounce {
            0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
            40% { transform: translateY(-4px); opacity: 1; }
        }

        /* ===== 数值步进 ===== */
        input[type="number"]::-webkit-outer-spin-button,
        input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        input[type="number"] { -moz-appearance: textfield; }
        .number-input-wrapper { position: relative; display: inline-block; }
        .number-input-wrapper input { padding-right: 36px !important; }
        .number-spin-buttons {
            position: absolute; right: 4px; top: 50%;
            transform: translateY(-50%);
            display: flex; flex-direction: column; gap: 2px;
        }
        .number-spin-btn {
            width: 24px; height: 12px;
            border: none; background: #f1f5f9;
            color: #64748b; font-size: 10px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            border-radius: 3px; transition: all 0.2s ease; padding: 0; line-height: 1;
        }
        .number-spin-btn:hover { background: #e2e8f0; color: #3b82f6; }
        .number-spin-btn:active { background: #3b82f6; color: white; }
        .number-spin-btn:disabled { opacity: 0.4; cursor: not-allowed; }
        .number-spin-btn:disabled:hover { background: #f1f5f9; color: #94a3b8; }

        /* ===== 知识/工具 Tab ===== */
        .knowledge-tabs .el-tabs__header { margin: 8px 0 12px 0; }
        .knowledge-tabs .el-tabs__nav-wrap::after { display: none; }
        .knowledge-tabs .el-tabs__item { padding: 0 14px; height: 32px; line-height: 32px; font-size: 13px; font-weight: 500; }
        .knowledge-tabs .el-tabs__active-bar { height: 2px; background-color: #3b82f6; }

        .animate-fade-in { animation: fadeIn 0.3s ease forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
        .cursor-blink { animation: blink 1s step-end infinite; }
        @keyframes blink { 50% { opacity: 0; } }
    </style>
</head>
<body id="app" v-cloak>

    <!-- ===== 顶部 Header ===== -->
    <header class="fixed top-0 left-0 right-0 h-14 bg-white border-b border-slate-200 z-50 flex items-center px-6" style="box-shadow: 0 2px 12px -2px rgba(15,23,42,0.08);">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-500 flex items-center justify-center shadow-lg shadow-blue-500/25">
                <el-icon class="text-white" style="font-size:18px;"><Avatar /></el-icon>
            </div>
            <div>
                <div class="text-sm font-bold text-slate-800">{{ form.name || '未命名数字员工' }}</div>
                <div class="text-xs font-medium" style="color:#10b981;">● 配置中</div>
            </div>
        </div>
        <div class="ml-6 h-6 w-px bg-slate-200"></div>
        <nav class="flex items-center gap-1 ml-4">
            <a v-for="item in navItems" :key="item.id"
               @click.prevent="scrollToSection(item.id)"
               :class="['flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium cursor-pointer transition-all',
                        activeSection === item.id ? 'bg-blue-50 text-blue-600' : 'text-slate-500 hover:bg-slate-50 hover:text-slate-700']">
                <el-icon class="text-xs"><component :is="item.icon" /></el-icon>
                {{ item.title }}
            </a>
        </nav>
        <div class="ml-auto flex gap-2">
            <el-button size="default" class="!rounded-lg !text-slate-600">取消</el-button>
            <el-button type="primary" size="default" @click="saveConfig" class="!rounded-lg !shadow-lg" style="box-shadow:0 4px 12px -2px rgba(59,130,246,0.35);">
                <el-icon class="mr-1"><Check /></el-icon>保存配置
            </el-button>
        </div>
    </header>

    <!-- ===== 主体两列布局 ===== -->
    <div class="flex" style="padding-top: 56px; height: 100vh;">

        <!-- 左列：配置表单 -->
        <div ref="contentContainer" class="flex-1 overflow-y-auto terminal-scroll" style="padding: 24px 28px 40px 28px; min-width: 0;">

            <!-- 基础配置 -->
            <div id="section-profile" class="module-card accent-blue">
                <div :class="['module-header', expandedSections.profile ? 'is-expanded' : '']" @click="toggleSection('profile')">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                            <el-icon class="text-blue-500" style="font-size:16px;"><User /></el-icon>
                        </div>
                        <div>
                            <div class="text-sm font-bold text-slate-800">基础配置</div>
                            <div class="text-xs text-slate-400 mt-0.5">员工名称、基座模型、职责描述</div>
                        </div>
                    </div>
                    <span :class="['icon-toggle', expandedSections.profile ? 'icon-toggle-expanded' : '']">▼</span>
                </div>
                <div v-show="expandedSections.profile" class="module-body animate-fade-in">
                    <div class="space-y-4">
                        <div>
                            <label class="form-label-simple">员工名称</label>
                            <el-input v-model="form.name" placeholder="例如：变压器异常诊断专家" size="large" class="!text-sm"></el-input>
                        </div>
                        <div>
                            <label class="form-label-simple">基座模型</label>
                            <div class="flex gap-2">
                                <el-select v-model="form.model" size="large" class="flex-1">
                                    <el-option label="Qwen-Max（推荐工业推理）" value="qwen"></el-option>
                                    <el-option label="GPT-4o（全能旗舰）" value="gpt4"></el-option>
                                </el-select>
                                <el-button size="large" icon="Setting" class="!rounded-md text-slate-600" @click="openModelDialog">模型参数</el-button>
                            </div>
                        </div>
                        <div>
                            <label class="form-label-simple">职责</label>
                            <el-input v-model="form.responsibility" type="textarea" :rows="4"
                                      placeholder="例如：你是一个严谨的电气工程师，主要负责一号车间的电气设备异常诊断..."
                                      size="large" class="!text-sm"></el-input>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 知识与工具 -->
            <div id="section-resources" class="module-card accent-emerald">
                <div :class="['module-header', expandedSections.resources ? 'is-expanded' : '']" @click="toggleSection('resources')">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center">
                            <el-icon class="text-emerald-500" style="font-size:16px;"><Box /></el-icon>
                        </div>
                        <div>
                            <div class="text-sm font-bold text-slate-800">知识与工具</div>
                            <div class="text-xs text-slate-400 mt-0.5">
                                知识库 {{ form.knowledge.rag.length + form.knowledge.faq.length + form.knowledge.db.length }} 项 · 工具 {{ form.tools.length }} 项
                            </div>
                        </div>
                    </div>
                    <span :class="['icon-toggle', expandedSections.resources ? 'icon-toggle-expanded' : '']">▼</span>
                </div>
                <div v-show="expandedSections.resources" class="module-body space-y-5 animate-fade-in">
                    <!-- 知识挂载 -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <h3 class="text-sm font-bold text-slate-700">【知识挂载】</h3>
                            <el-button size="small" icon="Plus" class="ai-magic-btn !text-xs" @click="openKnowledgeDialog">选择知识</el-button>
                        </div>
                        <div class="sub-card-simple space-y-3">
                            <div v-if="form.knowledge.rag.length === 0 && form.knowledge.faq.length === 0 && form.knowledge.db.length === 0"
                                 class="text-sm text-slate-400 italic text-center py-3">暂未挂载任何知识</div>
                            <div v-if="form.knowledge.rag.length > 0" class="space-y-2">
                                <div class="text-xs font-medium text-purple-600 flex items-center gap-1">
                                    <el-icon class="text-xs"><Document /></el-icon> 知识库（文档）
                                </div>
                                <div class="grid grid-cols-2 gap-2">
                                <div v-for="(kb, idx) in form.knowledge.rag" :key="'rag-'+idx"
                                     class="flex items-center gap-2 py-2 px-3 bg-purple-50/50 rounded-lg border border-purple-200/50">
                                    <span class="text-xs text-slate-700 flex-1 truncate">{{ kb }}</span>
                                    <el-button size="small" icon="Close" link class="!text-slate-400 hover:!text-rose-500 flex-shrink-0" @click="removeKnowledge('rag', idx)"></el-button>
                                </div>
                                </div>
                            </div>
                            <div v-if="form.knowledge.faq.length > 0" class="space-y-2">
                                <div class="text-xs font-medium text-amber-600 flex items-center gap-1">
                                    <el-icon class="text-xs"><ChatDotRound /></el-icon> 问答库（FAQ）
                                </div>
                                <div class="grid grid-cols-2 gap-2">
                                <div v-for="(faq, idx) in form.knowledge.faq" :key="'faq-'+idx"
                                     class="flex items-center gap-2 py-2 px-3 bg-amber-50/50 rounded-lg border border-amber-200/50">
                                    <span class="text-xs text-slate-700 flex-1 truncate">{{ faq }}</span>
                                    <el-button size="small" icon="Close" link class="!text-slate-400 hover:!text-rose-500 flex-shrink-0" @click="removeKnowledge('faq', idx)"></el-button>
                                </div>
                                </div>
                            </div>
                            <div v-if="form.knowledge.db.length > 0" class="space-y-2">
                                <div class="text-xs font-medium text-blue-600 flex items-center gap-1">
                                    <el-icon class="text-xs"><Coin /></el-icon> 数据库（DB）
                                </div>
                                <div class="grid grid-cols-2 gap-2">
                                <div v-for="(db, idx) in form.knowledge.db" :key="'db-'+idx"
                                     class="flex items-center gap-2 py-2 px-3 bg-blue-50/50 rounded-lg border border-blue-200/50">
                                    <span class="text-xs text-slate-700 flex-1 truncate">{{ db }}</span>
                                    <el-button size="small" icon="Close" link class="!text-slate-400 hover:!text-rose-500 flex-shrink-0" @click="removeKnowledge('db', idx)"></el-button>
                                </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 工具发放 -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <h3 class="text-sm font-bold text-slate-700">【工具发放】</h3>
                            <el-button size="small" icon="Plus" class="ai-magic-btn !text-xs" @click="openToolDialog">选择工具</el-button>
                        </div>
                        <div class="sub-card-simple">
                            <div v-if="form.tools.length === 0" class="text-sm text-slate-400 italic text-center py-3">暂未发放任何工具</div>
                            <div v-else class="grid grid-cols-2 gap-2">
                                <div v-for="(tool, idx) in form.tools" :key="'tool-'+idx"
                                     class="flex items-center gap-2 px-3 py-1.5 bg-slate-50 rounded-lg border border-slate-200">
                                    <span class="text-sm text-slate-700 flex-1 truncate">{{ tool }}</span>
                                    <el-button size="small" icon="Close" link class="!text-slate-400 hover:!text-rose-500 !p-0 flex-shrink-0" @click="removeTool(idx)"></el-button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 工作流程 -->
            <div id="section-logic" class="module-card accent-indigo">
                <div :class="['module-header', expandedSections.logic ? 'is-expanded' : '']" @click="toggleSection('logic')">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center">
                            <el-icon class="text-indigo-500" style="font-size:16px;"><Connection /></el-icon>
                        </div>
                        <div>
                            <div class="text-sm font-bold text-slate-800">工作流程</div>
                            <div class="text-xs text-slate-400 mt-0.5">
                                自主规划 {{ form.logic.allowExploration ? '开启' : '关闭' }} · SOP {{ form.sops.length }} 条
                            </div>
                        </div>
                    </div>
                    <span :class="['icon-toggle', expandedSections.logic ? 'icon-toggle-expanded' : '']">▼</span>
                </div>
                <div v-show="expandedSections.logic" class="module-body space-y-5 animate-fade-in">
                    <!-- 自主规划 -->
                    <div class="sub-card-simple">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="text-sm font-bold text-slate-800 mb-1 flex items-center gap-2">
                                    <div :class="['w-4 h-4 rounded-full border-2 transition-colors', form.logic.allowExploration ? 'bg-emerald-500 border-emerald-500' : 'bg-white border-slate-300']"></div>
                                    自主规划开关
                                </div>
                                <div class="text-xs text-slate-500 mt-2 leading-relaxed">开启后，当无相关SOPs时，可自行规划、拆解任务并采取执行动作。</div>
                            </div>
                            <el-switch v-model="form.logic.allowExploration" size="large"></el-switch>
                        </div>
                    </div>
                    <!-- 行为准则 -->
                    <div class="sub-card-simple">
                        <label class="form-label-simple flex items-center gap-1">
                            行为准则

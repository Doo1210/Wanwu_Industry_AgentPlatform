                    const selected = isToolSelected(tool);
                    const colors = { read: 'bg-emerald-50/50 border-emerald-300', control: 'bg-rose-50/50 border-rose-300', notify: 'bg-blue-50/50 border-blue-300', workflow: 'bg-cyan-50/50 border-cyan-300', plugin: 'bg-violet-50/50 border-violet-300' };
                    const hoverColors = { read: 'hover:border-emerald-300', control: 'hover:border-rose-300', notify: 'hover:border-blue-300', workflow: 'hover:border-cyan-300', plugin: 'hover:border-violet-300' };
                    return selected ? (colors[tool.type] || 'bg-blue-50/50 border-blue-300') : `bg-white border-slate-200 ${hoverColors[tool.type] || ''}`;
                };
                const getToolActiveColor = (tool) => {
                    const colors = { read: 'bg-emerald-500 border-emerald-500', control: 'bg-rose-500 border-rose-500', notify: 'bg-blue-500 border-blue-500', workflow: 'bg-cyan-500 border-cyan-500', plugin: 'bg-violet-500 border-violet-500' };
                    return colors[tool.type] || 'bg-blue-500 border-blue-500';
                };
                const selectedToolCount = computed(() => toolLibrary.value.filter(t => form.value.tools.includes(t.name)).length);
                const totalToolsCount = computed(() => toolLibrary.value.length);
                const isToolSelected = (tool) => form.value.tools.includes(tool.name);
                const toggleToolSelect = (tool) => {
                    const idx = form.value.tools.indexOf(tool.name);
                    idx > -1 ? form.value.tools.splice(idx, 1) : form.value.tools.push(tool.name);
                };
                const openToolDialog = () => { toolSearch.value = ''; showToolDialog.value = true; };
                const removeTool = (index) => { form.value.tools.splice(index, 1); };

                // ===== SOP =====
                const showSOPDialog = ref(false);
                const editingSOPIndex = ref(null);
                const sopDraft = ref({ businessDesc: '', compiledPrompt: '', autoTools: [], loading: false });

                const compileSOP = async () => {
                    if (!sopDraft.value.businessDesc) return;
                    sopDraft.value.loading = true;
                    await new Promise(r => setTimeout(r, 1500));
                    const desc = sopDraft.value.businessDesc;
                    if (desc.includes('油温') || desc.includes('温度')) {
                        sopDraft.value.compiledPrompt = `[SCENARIO]: Event alarm_type includes "Temperature" && value > 85\n[LOGIC]:\n  1. CALL [读取实时遥测数据] to check load over past 1 hour.\n  2. IF load is NORMAL, CALL [企业微信消息通知] to shift lead.\n  3. IF load is HIGH, CALL [设备急停/复位] IMMEDIATELY and CALL [派发维修工单].`;
                        sopDraft.value.autoTools = ['[读取实时遥测数据]', '[设备急停/复位]', '[企业微信消息通知]', '[派发维修工单]'];
                    } else {
                        sopDraft.value.compiledPrompt = `[SCENARIO]: Custom scenario from user input\n[LOGIC]:\n  1. Analyze the situation based on provided description.\n  2. Determine appropriate tools to use.\n  3. Execute actions as needed.`;
                        sopDraft.value.autoTools = [];
                    }
                    sopDraft.value.loading = false;
                };
                const highlightSOPLine = (line) => {
                    if (!line) return '';
                    return line
                        .replace(/\[([^\]]+)\]/g, '<span class="text-blue-600 font-bold">[$1]</span>')
                        .replace(/(IF|ELSE|CALL)/g, '<span class="text-purple-600 font-bold">$1</span>');
                };
                const openSOPDialog = () => {
                    sopDraft.value = { businessDesc: '', compiledPrompt: '', autoTools: [], loading: false };
                    editingSOPIndex.value = null;
                    showSOPDialog.value = true;
                };
                const saveSOP = () => {
                    form.value.sops.push({ id: 'sk_' + Date.now(), businessDesc: sopDraft.value.businessDesc, compiledPrompt: sopDraft.value.compiledPrompt, tools: sopDraft.value.autoTools });
                    showSOPDialog.value = false;
                };
                const openEditSOPDialog = (index) => {
                    editingSOPIndex.value = index;
                    const sop = form.value.sops[index];
                    sopDraft.value = { businessDesc: sop.businessDesc, compiledPrompt: sop.compiledPrompt, autoTools: sop.tools || [], loading: false };
                    showSOPDialog.value = true;
                };
                const updateSOP = () => {
                    if (editingSOPIndex.value !== null) {
                        form.value.sops[editingSOPIndex.value] = { ...form.value.sops[editingSOPIndex.value], businessDesc: sopDraft.value.businessDesc, compiledPrompt: sopDraft.value.compiledPrompt, tools: sopDraft.value.autoTools };
                    }
                    showSOPDialog.value = false;
                };
                const executeDeleteSOP = (index) => { form.value.sops.splice(index, 1); };

                // ===== 调试面板 =====
                const debugMessages = ref([]);
                const debugInput = ref('');
                const debugLoading = ref(false);

                const quickScenes = [
                    '变压器油温告警 87℃',
                    '设备负载突然升高',
                    '查询近1小时告警',
                    '派发巡检工单'
                ];

                const scrollDebugToBottom = () => {
                    nextTick(() => {
                        if (debugContainer.value) {
                            debugContainer.value.scrollTop = debugContainer.value.scrollHeight;
                        }
                    });
                };

                const sendDebugMessage = async () => {
                    if (!debugInput.value.trim() || debugLoading.value) return;
                    const userMsg = debugInput.value.trim();
                    debugMessages.value.push({ role: 'user', content: userMsg });
                    debugInput.value = '';
                    debugLoading.value = true;
                    scrollDebugToBottom();

                    // 思考中
                    debugMessages.value.push({ role: 'thinking', content: '正在分析事件...' });
                    scrollDebugToBottom();
                    await new Promise(r => setTimeout(r, 900));
                    debugMessages.value.pop();

                    // 工具调用
                    if (userMsg.includes('油温') || userMsg.includes('温度') || userMsg.includes('告警')) {
                        debugMessages.value.push({ role: 'tool', content: 'CALL [读取实时遥测数据]\n→ 油温: 87℃  负载: 92%  运行时长: 4.2h' });
                        scrollDebugToBottom();
                        await new Promise(r => setTimeout(r, 700));
                        debugMessages.value.push({ role: 'tool', content: 'CALL [DB] 查询历史台账与告警\n→ 近1小时触发告警 3 次，负载持续偏高' });
                        scrollDebugToBottom();
                        await new Promise(r => setTimeout(r, 500));
                        debugMessages.value.push({ role: 'assistant', content: '检测到变压器油温异常（87℃ > 85℃），同时负载持续偏高（92%），触发高危判定。\n\n已按SOP执行：\n① 发送企业微信告警通知至班长\n② 触发设备急停指令（等待人工审批确认）\n③ 创建维修工单 #WO-20240520-001' });
                    } else if (userMsg.includes('工单') || userMsg.includes('巡检')) {
                        debugMessages.value.push({ role: 'tool', content: 'CALL [OA] 派发维修工单\n→ 工单创建成功: #WO-' + Date.now().toString().slice(-6) });
                        scrollDebugToBottom();
                        await new Promise(r => setTimeout(r, 600));
                        debugMessages.value.push({ role: 'assistant', content: '已成功派发巡检工单，工单号已生成。相关人员将收到通知。' });
                    } else if (userMsg.includes('查询') || userMsg.includes('历史')) {
                        debugMessages.value.push({ role: 'tool', content: 'CALL [DB] 查询历史台账与告警\n→ 返回近24小时记录 156 条，异常 12 条' });
                        scrollDebugToBottom();
                        await new Promise(r => setTimeout(r, 600));
                        debugMessages.value.push({ role: 'assistant', content: '已查询历史台账，近24小时共记录 156 条运行数据，其中异常记录 12 条。主要集中在凌晨2点至4点负载高峰期。' });
                    } else {
                        debugMessages.value.push({ role: 'assistant', content: '我已收到您的指令。根据当前配置的工具和SOP，我将分析相关情况并给出处理建议。请提供更多具体信息以便我做出更准确的响应。' });
                    }

                    scrollDebugToBottom();
                    debugLoading.value = false;
                };

                const sendQuickScene = (scene) => {
                    debugInput.value = scene;
                    sendDebugMessage();
                };

                const clearDebug = () => {
                    debugMessages.value = [];
                };

                watch(debugMessages, scrollDebugToBottom, { deep: true });

                // ===== 保存 =====
                const saveConfig = () => {
                    ElementPlus.ElMessage.success('配置保存成功！');
                };

                return {
                    contentContainer, debugContainer,
                    activeSection, navItems, scrollToSection,
                    expandedSections, toggleSection,
                    form, saveConfig,
                    showModelDialog, modelConfig, modelParams, adjustValue, openModelDialog,
                    showSecurityDialog, securityForm, openSecurityDialog, openEditSecurityConfig,
                    saveSecurityConfig, updateSecurityConfig, removeSecurityConfig,
                    addValueBound, removeValueBound,
                    showKnowledgeDialog, knowledgeSearch, knowledgeActiveTab,
                    knowledgeLibrary, faqLibrary, dbLibrary, filteredDocLibrary,
                    selectedKnowledgeCount, isKnowledgeSelected, toggleKnowledgeSelect,
                    openKnowledgeDialog, removeKnowledge,
                    showToolDialog, toolSearch, activeToolTab,
                    toolLibrary, filteredAllTools, filteredToolsByTab,
                    selectedToolCount, totalToolsCount,
                    isToolSelected, toggleToolSelect, getToolCardClass, getToolActiveColor,
                    openToolDialog, removeTool,
                    showSOPDialog, editingSOPIndex, sopDraft,
                    compileSOP, highlightSOPLine,
                    openSOPDialog, saveSOP, openEditSOPDialog, updateSOP, executeDeleteSOP,
                    debugMessages, debugInput, debugLoading, quickScenes,
                    sendDebugMessage, sendQuickScene, clearDebug
                };
            }
        });
        app.use(ElementPlus);
        for (const [key, component] of Object.entries(ElementPlusIconsVue)) {
            app.component(key, component);
        }
        app.mount('#app');
    </script>
</body>
</html>

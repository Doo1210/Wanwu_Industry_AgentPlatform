                ]);
                const filteredDocLibrary = computed(() => {
                    if (!knowledgeSearch.value) return knowledgeLibrary.value;
                    return knowledgeLibrary.value.filter(d => d.name.toLowerCase().includes(knowledgeSearch.value.toLowerCase()));
